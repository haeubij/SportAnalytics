meta {
  name: Register Admin
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "username": "adminuser",
    "email": "admin@sport.ch",
    "password": "admin123",
    "role": "admin"
  }
}

assert {
  res.status: eq 201
  res.body.token: isDefined
  res.body.user.role: eq admin
}
