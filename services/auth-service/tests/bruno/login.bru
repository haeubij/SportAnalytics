meta {
  name: Login
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "testuser@sport.ch",
    "password": "password123"
  }
}

vars:pre-request {
  baseUrl:  http://localhost:3002
}

assert {
  res.status: eq 200
  res.body.token: isDefined
  res.body.user.email: eq testuser@sport.ch
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("authToken", res.body.token);
  }
}
