meta {
  name: Register User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "username": "Janis",
    "email": "testuser@sport.ch",
    "password": "password123"
  }
}

vars:pre-request {
  baseUrl: http://localhost:3002
}

assert {
  res.status: eq 201
  res.body.token: isDefined
  res.body.user.email: eq testuser@sport.ch
}
