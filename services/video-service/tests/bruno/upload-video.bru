meta {
  name: Upload Video JSON
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/videos
  body: json
  auth: none
}

headers {
  x-auth-token: {{authToken}}
}

body:json {
  {
    "title": "TestVideo",
    "description": "TrainingHighlights",
    "sport": "football",
    "filename": "test.mp4",
    "contentType": "video/mp4",
    "data": "AAAAIGZ0eXBtcDQyAAAAAG1wNDJtcDQxaXNvbQ=="
  }
}

vars:pre-request {
  baseUrl: http://localhost:3003
}

assert {
  res.status: eq 201
  res.body.video.id: isDefined
}
