meta {
  name: Create User and Verify DB
  type: http
  seq: 10
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "username": "dbtest_{{$timestamp}}",
    "email": "dbtest_{{$timestamp}}@test.com",
    "password": "Test1234!"
  }
}

tests {
  test("POST /register creates user in DB - status 201", function() {
    expect(res.status).to.equal(201);
  });
  test("POST /register returns user object (DB entry created)", function() {
    expect(res.body.user).to.not.be.undefined;
    expect(res.body.user.id).to.not.be.undefined;
    expect(res.body.token).to.not.be.undefined;
  });
  test("POST /register - username matches input (DB stored correctly)", function() {
    expect(res.body.user.email).to.include("dbtest_");
  });
}

script:post-response {
  bru.setVar("createdUserId", res.body.user.id);
  bru.setVar("authToken", res.body.token);
}
